# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# Gemini API key (free, from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Gmail sender credentials
GMAIL_USER=codjogahito@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx  # 16-char App Password from Google

# Recipients (comma-separated)
RECIPIENTS=codjo.gahito@outlook.com,codjo.gahito@natixis.com

# Streamlit dashboard URL (set after Phase 4)
STREAMLIT_URL=https://your-app.streamlit.app

# Optional: dashboard password (leave empty for public access)
DASHBOARD_PASSWORD=
